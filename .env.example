# Copy this file to `.env` and set values locally. Never commit `.env`.

# Optional: MongoDB. Put your real URI only in `.env` — keep this file empty of secrets
# (this template is safe to commit). Example shape:
# mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/mySwaggerApiDb?retryWrites=true&w=majority
MONGODB_URI=

# Optional
UNSPLASH_ACCESS_KEY=
PORT=
